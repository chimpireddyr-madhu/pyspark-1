# 2. PySpark ImplementationIn PySpark, you can achieve this using the highly optimized left_anti join type [2]. An anti-join automatically returns rows from the left DataFrame where no match exists in the right DataFrame [2].
    
from pyspark.sql import SparkSession
from pyspark.sql.functions import col

# 1. Initialize Spark Session
spark = SparkSession.builder \
    .appName("FindEmployeesWithoutDepartment") \
    .getOrCreate()

# 2. Create Sample Employee Data (Simulating missing/null/invalid dept IDs)
employee_data = [
    (1, "Dev Lead 1", "Architect", 101),
    (2, "Dev 1", "Senior Developer", 101),
    (3, "Dev 5", "DevOps Engineer", 999),  # 999 doesn't exist in departments
    (4, "Dev 11", "Security Engineer", None) # None/Null department
]
employee_schema = ["employee_id", "employee_name", "role", "department_id"]
df_employees = spark.createDataFrame(employee_data, schema=employee_schema)

# 3. Create Sample Department Data
department_data = [
    (101, "On-Prem Core Pod"),
    (102, "AWS Cloud Pod"),
    (103, "Azure Data Pod"),
    (104, "GCP Analytics Pod")
]
department_schema = ["department_id", "department_name"]
df_departments = spark.createDataFrame(department_data, schema=department_schema)

# 4. Execute Left-Anti Join to isolate unmatched employees
df_orphaned_employees = df_employees.join(
    df_departments,
    df_employees["department_id"] == df_departments["department_id"],
    how="left_anti"
)

# 5. Show results in console
print("Employees without a valid department:")
df_orphaned_employees.select("employee_id", "employee_name", "role", "department_id").show()

  
    
    
   
   
